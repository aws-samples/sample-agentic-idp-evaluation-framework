# AWS Configuration
AWS_REGION=us-west-2
AWS_PROFILE=default

# S3 — Use a real S3 bucket (no local storage fallback)
S3_BUCKET=your-bucket-name
S3_OUTPUT_PREFIX=idp-outputs/

# BDA — Standard profile ARN (required for BDA methods)
# Replace ACCOUNT_ID with your AWS account ID
BDA_PROFILE_ARN=arn:aws:bedrock:us-west-2:ACCOUNT_ID:data-automation-profile/us.data-automation-v1
# BDA Custom — Leave empty to skip BDA Custom output
BDA_PROJECT_ARN=

# Models (Latest: Opus 4.6, Sonnet 4.6, Haiku 4.5)
CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-4-6
NOVA_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Authentication (Midway - internal AWS employees only)
# Set to true for local development without Midway
MIDWAY_DISABLED=true

# Server
PORT=3001
FRONTEND_URL=http://localhost:5180

# NOTE: Due to ESM import hoisting, start the backend with:
#   node --env-file=.env --import=tsx packages/backend/src/index.ts
# The dotenv import in index.ts is a fallback but --env-file is more reliable.
