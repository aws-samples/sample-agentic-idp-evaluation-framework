# ============================================================================
# ONE IDP — Environment configuration
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in your values. Never commit `.env` with real
# secrets. This file is safe to check in.
# ============================================================================

# --- AWS ---------------------------------------------------------------------
AWS_REGION=us-west-2
# Optional: named profile if you have multiple AWS accounts configured locally.
# AWS_PROFILE=default

# --- Storage -----------------------------------------------------------------
# S3 bucket for uploads + processing outputs. Leave blank and set
# USE_LOCAL_STORAGE=true to use `.local-uploads/` for local dev.
S3_BUCKET=
S3_OUTPUT_PREFIX=idp-outputs/
# USE_LOCAL_STORAGE=true

# --- Bedrock models ----------------------------------------------------------
# Defaults are GA models in us-west-2. Change only if you need a regional
# variant or a different model tier.
CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-4-6
NOVA_MODEL_ID=us.amazon.nova-2-lite-v1:0

# --- Bedrock Data Automation (BDA) ------------------------------------------
# Required for BDA-based processing methods. Replace ACCOUNT_ID with yours.
# Example: arn:aws:bedrock:us-west-2:123456789012:data-automation-profile/us.data-automation-v1
BDA_PROFILE_ARN=
# Optional: custom blueprint / project ARN. Leave empty to skip BDA Custom.
BDA_PROJECT_ARN=

# --- Authentication ----------------------------------------------------------
# AUTH_PROVIDER: "none" (demo) | "midway" (AWS internal) | "cognito" (stub)
AUTH_PROVIDER=none
# When AUTH_PROVIDER=none, the backend refuses to start in production unless
# you explicitly opt in:
# ALLOW_UNAUTHENTICATED=true
# When AUTH_PROVIDER=cognito, fill these in:
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# Comma-separated list of admin aliases granted the /admin page.
ADMIN_USERS=

# Legacy toggle — kept for back-compat. Same as AUTH_PROVIDER=none.
# MIDWAY_DISABLED=true

# --- Server ------------------------------------------------------------------
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
# Public site URL (used by auth redirects). Leave blank for local dev.
# SITE_URL=https://idp.example.com

# --- Agent runtime (AgentCore) ----------------------------------------------
# Populated by Terraform/CDK outputs after deploy. In local dev, leave blank
# to run the agent in-process.
AGENTCORE_RUNTIME_ARN=
# Optional: override activity table (DynamoDB). Default: one-idp-activity
# ACTIVITY_TABLE=one-idp-activity

# --- Frontend (Vite) — these are read at build time ------------------------
# Shown in the top nav when set. Leave blank in public builds.
# VITE_APP_TITLE=ONE IDP Framework
# VITE_REPO_URL=
# VITE_REPO_LABEL=Source
# VITE_CHAT_URL=
# VITE_CHAT_LABEL=Chat

# ============================================================================
# NOTE: Start the backend with:
#   node --env-file=.env --import=tsx packages/backend/src/index.ts
# The dotenv import in index.ts is a fallback, but --env-file is more reliable
# for ESM hoisting order.
# ============================================================================
