        <!-- Footer caption -->
        <mxCell id="footer" parent="1" style="text;html=1;fontSize=10;align=center;verticalAlign=middle;fontFamily=Amazon Ember;fontColor=#A1A1AA;" value="5-tier topology  ·  Terraform &amp; CDK parity  ·  Least-privilege IAM  ·  MIT-0" vertex="1">
