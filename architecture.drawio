        <!-- Web → Agent (SigV4) -->
        <mxCell id="e_ecs_ac" edge="1" parent="1" source="ecs_icon" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#01A88D;strokeWidth=2;fontSize=10;fontColor=#01A88D;fontStyle=1;fontFamily=Amazon Ember;endArrow=classicThin;endSize=8;endFill=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;labelBackgroundColor=#FFFFFF;labelBorderColor=none;" target="ac_icon" value="SigV4">
          <mxGeometry relative="1" y="-10" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Agent → Bedrock FM. Simply enters the top of the FM card at the
             icon position; no header to cross because the FM icon sits high
             enough in the card. -->
        <mxCell id="e_ac_br" edge="1" parent="1" source="ac_icon" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#01A88D;strokeWidth=2;endArrow=classicThin;endSize=8;endFill=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" target="br_card">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="96" y="595" />
              <mxPoint x="96" y="769" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Web → AI direct (for SSE streaming methods).
             Routed through a right-side gutter at x=1320 so they don't cross
             the Agent lane text. No edge labels — legend-by-color only. -->
        <!-- Exit ECS on the right → drop through the far-right gutter x=1388 →
             enter each AI card's RIGHT side (not the top) so we skip the
             "04 AI SERVICES" lane header band entirely. -->
        <!-- Three ECS → AI-service arrows. Each takes a different lane in
             the right gutter so horizontal segments don't overlap, and each
             enters its target card from the TOP (not the right side) at a
             position below the lane header, using the gutter above the card
             which is outside other cards' bounding boxes.
             Actually simplest: Textract card is rightmost so its arrow drops
             straight down the gutter into its right edge. BDA card is
             middle so its arrow goes down the gutter then crosses just the
             AI-lane sidebar area (empty). Bedrock FM card is leftmost so
             its arrow needs the most lateral travel — we route it ABOVE the
             lane rather than through it. -->
        <!-- Textract: drop straight down the gutter, enter right side. -->
        <mxCell id="e_ecs_tx" edge="1" parent="1" source="ecs_icon" style="edgeStyle=none;html=1;strokeColor=#991B1B;strokeWidth=2;endArrow=classicThin;endSize=8;endFill=1;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" target="tx_card">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1388" y="452" />
              <mxPoint x="1388" y="769" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- BDA: drop down the gutter, enter right side (crosses between
             Textract and BDA cards only). -->
        <mxCell id="e_ecs_bda" edge="1" parent="1" source="ecs_icon" style="edgeStyle=none;html=1;strokeColor=#9A3412;strokeWidth=2;endArrow=classicThin;endSize=8;endFill=1;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" target="bda_card">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1395" y="452" />
              <mxPoint x="1395" y="862" />
              <mxPoint x="920" y="862" />
              <mxPoint x="920" y="769" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Bedrock FM: drop down the gutter, run under all AI cards along
             the lane-bottom, then enter Bedrock card from its right. -->
        <mxCell id="e_ecs_br" edge="1" parent="1" source="ecs_icon" style="edgeStyle=none;html=1;strokeColor=#5B21B6;strokeWidth=2;endArrow=classicThin;endSize=8;endFill=1;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" target="br_card">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1402" y="452" />
              <mxPoint x="1402" y="868" />
              <mxPoint x="536" y="868" />
              <mxPoint x="536" y="769" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Data plane -->
        <mxCell id="e_ecs_s3u" edge="1" parent="1" source="ecs_icon" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3F8624;strokeWidth=2;endArrow=classicThin;endSize=8;endFill=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" target="s3u">
