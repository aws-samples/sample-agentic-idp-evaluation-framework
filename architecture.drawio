        <mxCell id="e_bda_s3u" edge="1" parent="1" source="bda_icon" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3F8624;strokeWidth=1;endArrow=classicThin;endSize=6;endFill=1;dashed=1;dashPattern=3 3;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" target="s3u">
