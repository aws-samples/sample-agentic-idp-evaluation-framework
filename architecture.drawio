        <mxCell id="e_ecs_ddb" edge="1" parent="1" source="ecs_icon" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C925D1;strokeWidth=2;endArrow=classicThin;endSize=8;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="ddb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ecs_sqs" edge="1" parent="1" source="ecs_icon" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C925D1;strokeWidth=1;endArrow=classicThin;endSize=6;endFill=1;dashed=1;dashPattern=3 3;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" target="sqs">
