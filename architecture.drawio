        <mxCell id="e_cf_alb" edge="1" parent="1" source="cf" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF9900;strokeWidth=2;fontSize=10;fontColor=#FF9900;fontFamily=Amazon Ember;endArrow=classicThin;endSize=8;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;labelBackgroundColor=#FFFFFF;" target="alb" value="/api/*">
